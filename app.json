{
  "expo": {
    "name": "Unchainly",
    "slug": "unchainly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "unchainly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dotorbit.unchainly",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.dotorbit.unchainly",
      "adaptiveIcon": {
        "backgroundColor": "#5A2E7A",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FBF6EF",
          "dark": {
            "backgroundColor": "#1A1420"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Unchainly uses a photo only as the background for the progress card you choose to share. Photos never leave your device otherwise."
        }
      ],
      "expo-audio",
      "expo-notifications",
      "expo-asset",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Unchainly uses your location only while a walk session is running, to measure how far you walked. Your location never leaves this device.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Unchainly uses motion data only to count your steps during walk sessions. Step data never leaves this device."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
